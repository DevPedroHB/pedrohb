{
	"$schema": "https://turborepo.dev/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": [".next/**", "!.next/cache/**", "!.next/dev/**", "dist/**"]
		},
		"check": {
			"dependsOn": ["^check"]
		},
		"format": {
			"dependsOn": ["^format"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"start:dev": {
			"cache": false,
			"persistent": true
		},
		"start:prod": {
			"cache": false,
			"persistent": true
		},
		"test": {
			"dependsOn": ["^test"],
			"outputs": ["coverage/**"]
		},
		"test:e2e": {
			"dependsOn": ["^test:e2e"],
			"outputs": ["coverage/**"]
		},
		"typecheck": {
			"dependsOn": ["^typecheck"]
		}
	},
	"ui": "tui"
}
